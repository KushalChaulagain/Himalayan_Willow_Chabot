VITE_API_URL=http://localhost:8000

# Google OAuth Client ID for "Continue with Google" (same as backend GOOGLE_CLIENT_ID)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Mapbox Access Token (optional) - Enables real static map thumbnails on LocationCard
# Get from https://account.mapbox.com/access-tokens/ (free tier: 50k static map requests/month)
# VITE_MAPBOX_ACCESS_TOKEN=pk.eyJ1...

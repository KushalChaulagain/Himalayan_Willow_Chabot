# LLM Configuration (required for chat)
# Get your API key from https://makersuite.google.com/app/apikey
# The chatbot uses gemini-1.5-flash model (free tier compatible)
GEMINI_API_KEY=your_gemini_api_key_here

# Fallback LLM: Used when Gemini is slow (>10s) or unavailable
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Database (optional: leave empty or comment out to run without PostgreSQL; app starts but order/chat persistence endpoints return 503)
# Use the same user/password as in pgAdmin. Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:your_postgres_password@localhost:5432/himalayan_willow

# Payment Gateways
ESEWA_MERCHANT_ID=your_esewa_merchant_id
ESEWA_SECRET_KEY=your_esewa_secret_key
ESEWA_BASE_URL=https://uat.esewa.com.np  # Use production URL for live
KHALTI_SECRET_KEY=your_khalti_secret_key
KHALTI_BASE_URL=https://khalti.com  # Khalti API base URL

# Notifications
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
RESEND_API_KEY=your_resend_api_key

# Google OAuth (for "Continue with Google" sign-in)
# Get from Google Cloud Console -> APIs & Services -> Credentials -> OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Application
BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
JWT_SECRET=your_jwt_secret_key_here
ENVIRONMENT=development

# Store Configuration
STORE_ID=1
STORE_NAME=Himalayan Willow
# Google Maps link for store location (used when customers ask for directions/pickup)
STORE_MAPS_URL=https://maps.app.goo.gl/WiWrohWFkAWWHput8
# Optional: Store phone for "Call Us" (e.g. +977-1-1234567)
STORE_PHONE=
